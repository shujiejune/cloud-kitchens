# Copy this file to .env and fill in real values before running docker-compose.
# Never commit the .env file to version control.

# MySQL
DB_PASSWORD=yourpassword
DB_NAME=cloudkitchens_db
DB_PORT=3307

# JWT (must be at least 32 bytes / 256 bits for HS256)
JWT_SECRET=your-256-bit-secret-key-for-validating-tokens

# Vendor API endpoints (replace placeholders before going to prod)
VENDOR_AMAZON_URL=https://api.amazon.example.com
VENDOR_WALMART_URL=https://api.walmart.example.com
VENDOR_KROGER_URL=https://api.kroger.example.com
